#!/bin/sh
#
# agent-sync -- deploy agent config from AGENT_PATH to tool-specific locations
#
# Scans each directory in AGENT_PATH for skills/ and commands/ subdirs,
# then symlinks them into Claude, OpenCode, and other tool directories.
#
# Also syncs from marketplace-enabled directories if they exist.
# AGENT_PATH is colon-separated, like PATH. Defaults to ~/.dotfiles/agents.
#
# Usage:
#   agent-sync              # symlink everything
#   agent-sync --copy       # hard-copy instead of symlink
#   agent-sync --dry-run    # preview without changes
#   agent-sync --marketplace-only  # only sync marketplace, not AGENT_PATH

set -e

AGENT_PATH="${AGENT_PATH:-$HOME/.dotfiles/agents}"
AGENTS_DIR="${AGENTS_DIR:-$HOME/.dotfiles/agents}"

CLAUDE_SKILLS="$HOME/.claude/skills"
CURSOR_SKILLS="$HOME/.cursor/skills"
CURSOR_COMMANDS="$HOME/.cursor/commands"
OPENCODE_SKILLS="$HOME/.config/opencode/skills"
OPENCODE_COMMANDS="$HOME/.config/opencode/command"

MARKETPLACE_SKILLS_ENABLED="$AGENTS_DIR/marketplace/skills-enabled"
MARKETPLACE_COMMANDS_ENABLED="$AGENTS_DIR/marketplace/commands-enabled"
MARKETPLACE_AGENTS_ENABLED="$AGENTS_DIR/marketplace/agents-enabled"
MARKETPLACE_HOOKS_ENABLED="$AGENTS_DIR/marketplace/hooks-enabled"
MARKETPLACE_MCP_ENABLED="$AGENTS_DIR/marketplace/mcp-enabled"

MODE="symlink"
DRY_RUN=false
MARKETPLACE_ONLY=false

for arg in "$@"; do
  case "$arg" in
    --copy)    MODE="copy" ;;
    --dry-run) DRY_RUN=true ;;
    --marketplace-only) MARKETPLACE_ONLY=true ;;
    --help|-h)
      echo "Usage: agent-sync [--copy] [--dry-run] [--marketplace-only]"
      echo ""
      echo "Deploys agent config from AGENT_PATH to tool-specific locations."
      echo "AGENT_PATH is colon-separated (current: $AGENT_PATH)"
      echo ""
      echo "Also syncs from marketplace-enabled directories (skills-enabled,"
      echo "commands-enabled, etc.) to the tool-specific locations."
      echo ""
      echo "Options:"
      echo "  --copy            Hard-copy files instead of symlinking"
      echo "  --dry-run         Preview what would be done without making changes"
      echo "  --marketplace-only Only sync marketplace, not AGENT_PATH"
      exit 0
      ;;
    *)
      echo "Unknown option: $arg" >&2
      exit 1
      ;;
  esac
done

link_or_copy() {
  local src="$1"
  local dest="$2"

  if [ "$DRY_RUN" = true ]; then
    echo "  [dry-run] $src -> $dest"
    return
  fi

  if [ -L "$dest" ]; then
    local current
    current=$(readlink "$dest")
    if [ "$current" = "$src" ]; then
      echo "  [ok] $dest (already linked)"
      return
    fi
    rm "$dest"
  elif [ -e "$dest" ]; then
    echo "  [warn] $dest exists and is not a symlink, skipping"
    return
  fi

  mkdir -p "$(dirname "$dest")"

  if [ "$MODE" = "copy" ]; then
    cp -R "$src" "$dest"
    echo "  [copied] $src -> $dest"
  else
    ln -s "$src" "$dest"
    echo "  [linked] $src -> $dest"
  fi
}

synced=0

IFS=':'
for agents_dir in $AGENT_PATH; do
  unset IFS

  [ -d "$agents_dir" ] || continue
  echo "source: $agents_dir"

  # Skills -> Claude + Cursor + OpenCode
  if [ -d "$agents_dir/skills" ]; then
    for skill in "$agents_dir/skills"/*/; do
      [ -d "$skill" ] || continue
      name=$(basename "$skill")
      echo "  skill: $name"
      link_or_copy "$skill" "$CLAUDE_SKILLS/$name"
      link_or_copy "$skill" "$CURSOR_SKILLS/$name"
      link_or_copy "$skill" "$OPENCODE_SKILLS/$name"
      synced=$((synced + 1))
    done
  fi

  # Commands -> Cursor + OpenCode
  if [ -d "$agents_dir/commands" ]; then
    for cmd in "$agents_dir/commands"/*; do
      [ -f "$cmd" ] || continue
      name=$(basename "$cmd")
      echo "  command: $name"
      link_or_copy "$cmd" "$CURSOR_COMMANDS/$name"
      link_or_copy "$cmd" "$OPENCODE_COMMANDS/$name"
      synced=$((synced + 1))
    done
  fi
done
unset IFS

if [ "$synced" -eq 0 ]; then
  echo "Nothing to sync. Add skills or commands to a directory in AGENT_PATH."
else
  echo ""
  echo "Synced $synced item(s)."
fi

# Sync from marketplace-enabled directories
if [ -d "$MARKETPLACE_SKILLS_ENABLED" ] || [ -d "$MARKETPLACE_COMMANDS_ENABLED" ] || [ -d "$MARKETPLACE_AGENTS_ENABLED" ] || [ -d "$MARKETPLACE_HOOKS_ENABLED" ] || [ -d "$MARKETPLACE_MCP_ENABLED" ]; then
  echo ""
  echo "=== Marketplace Sync ==="

  # Sync skills from marketplace
  if [ -d "$MARKETPLACE_SKILLS_ENABLED" ]; then
    echo "source: marketplace skills-enabled"
    for link in "$MARKETPLACE_SKILLS_ENABLED"/*; do
      [ -e "$link" ] || continue
      name=$(basename "$link")
      # Extract skill name before the @marketplace suffix
      skill_name=$(echo "$name" | sed 's/@.*$//')
      echo "  marketplace skill: $name"
      link_or_copy "$link" "$CLAUDE_SKILLS/$skill_name"
      link_or_copy "$link" "$CURSOR_SKILLS/$skill_name"
      link_or_copy "$link" "$OPENCODE_SKILLS/$skill_name"
      synced=$((synced + 1))
    done
  fi

  # Sync commands from marketplace
  if [ -d "$MARKETPLACE_COMMANDS_ENABLED" ]; then
    echo "source: marketplace commands-enabled"
    for link in "$MARKETPLACE_COMMANDS_ENABLED"/*; do
      [ -e "$link" ] || continue
      name=$(basename "$link")
      # Extract command name before the @marketplace suffix
      cmd_name=$(echo "$name" | sed 's/@.*$//')
      echo "  marketplace command: $name"
      link_or_copy "$link" "$CURSOR_COMMANDS/$cmd_name"
      link_or_copy "$link" "$OPENCODE_COMMANDS/$cmd_name"
      synced=$((synced + 1))
    done
  fi

  # Sync agents from marketplace (to Claude and OpenCode)
  if [ -d "$MARKETPLACE_AGENTS_ENABLED" ]; then
    echo "source: marketplace agents-enabled"
    # Agents typically go to ~/.claude/agents/ and ~/.config/opencode/agents/
    CLAUDE_AGENTS="$HOME/.claude/agents"
    OPENCODE_AGENTS="$HOME/.config/opencode/agents"
    for link in "$MARKETPLACE_AGENTS_ENABLED"/*; do
      [ -e "$link" ] || continue
      name=$(basename "$link")
      agent_name=$(echo "$name" | sed 's/@.*$//')
      echo "  marketplace agent: $name"
      link_or_copy "$link" "$CLAUDE_AGENTS/$agent_name"
      link_or_copy "$link" "$OPENCODE_AGENTS/$agent_name"
      synced=$((synced + 1))
    done
  fi

  # Sync hooks from marketplace
  if [ -d "$MARKETPLACE_HOOKS_ENABLED" ]; then
    echo "source: marketplace hooks-enabled"
    for link in "$MARKETPLACE_HOOKS_ENABLED"/*; do
      [ -e "$link" ] || continue
      name=$(basename "$link")
      echo "  marketplace hooks: $name"
      # Copy hooks.json content to tool-specific locations
      # Claude uses ~/.claude/settings.json, OpenCode uses different config
      # For now, just copy to the skills directories as that's common
      link_or_copy "$link" "$CLAUDE_SKILLS/../settings.json"
      synced=$((synced + 1))
    done
  fi

  # Sync MCP from marketplace
  if [ -d "$MARKETPLACE_MCP_ENABLED" ]; then
    echo "source: marketplace mcp-enabled"
    for link in "$MARKETPLACE_MCP_ENABLED"/*; do
      [ -e "$link" ] || continue
      name=$(basename "$link")
      echo "  marketplace mcp: $name"
      link_or_copy "$link" "$CLAUDE_SKILLS/../.mcp.json"
      link_or_copy "$link" "$HOME/.config/opencode/.mcp.json"
      synced=$((synced + 1))
    done
  fi
fi

echo ""
echo "Total synced: $synced item(s)."
