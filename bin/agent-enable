#!/usr/bin/env -S uv run --with claude-code-plugins-sdk --script
#
# agent-enable -- enable skills and commands from local agents directories
#
# Usage:
#   agent-enable <name>              # Enable skill or command by name
#   agent-enable --list              # Show available skills/commands
#   agent-enable --help              # Show help
#
# Examples:
#   agent-enable my-skill
#   agent-enable my-command
#   agent-enable --list

import os
import sys
from pathlib import Path

AGENTS_DIR = Path(os.environ.get('AGENTS_DIR', Path.home() / '.dotfiles' / 'agents'))
SKILLS_ENABLED = AGENTS_DIR / 'skills-enabled'
COMMANDS_ENABLED = AGENTS_DIR / 'commands-enabled'

ENABLED_DIRS = {
    'skills': SKILLS_ENABLED,
    'commands': COMMANDS_ENABLED,
}

def ensure_dirs():
    for d in ENABLED_DIRS.values():
        d.mkdir(parents=True, exist_ok=True)

def list_components(agents_dir: Path) -> dict:
    components = {'skills': [], 'commands': []}
    
    if not agents_dir.exists():
        return components
    
    skills_dir = agents_dir / 'skills'
    if skills_dir.exists():
        for item in skills_dir.iterdir():
            if item.is_dir():
                components['skills'].append(item.name)
    
    commands_dir = agents_dir / 'commands'
    if commands_dir.exists():
        for item in commands_dir.iterdir():
            if item.is_file() and item.suffix == '.md':
                components['commands'].append(item.stem)
    
    return components

def find_component(name: str) -> tuple:
    IFS=':'
    for agents_dir_str in os.environ.get('AGENT_PATH', str(AGENTS_DIR)).split(':'):
        agents_dir = Path(agents_dir_str)
        if not agents_dir.exists():
            continue
        
        for comp_type in ['skills', 'commands']:
            source_dir = agents_dir / comp_type
            if not source_dir.exists():
                continue
            
            if comp_type == 'skills':
                source_path = source_dir / name
                if source_path.exists() and source_path.is_dir():
                    return comp_type, source_path
            else:
                source_path = source_dir / f'{name}.md'
                if source_path.exists() and source_path.is_file():
                    return comp_type, source_path
    
    return None, None

def enable_component(component_type: str, name: str, source_path: Path):
    enabled_dir = ENABLED_DIRS.get(component_type)
    if not enabled_dir:
        print(f"  [error] Unknown component type: {component_type}")
        return False
    
    link_path = enabled_dir / name
    
    if link_path.exists() or link_path.is_symlink():
        print(f"  [skip] Already enabled: {name} ({component_type})")
        return False
    
    try:
        rel_path = os.path.relpath(source_path, enabled_dir)
        os.symlink(rel_path, link_path)
        print(f"  [enabled] {name} ({component_type})")
        return True
    except OSError as e:
        print(f"  [error] Failed to create symlink: {e}")
        return False

def list_available():
    ensure_dirs()
    
    print("Available in AGENT_PATH:")
    print()
    
    IFS=':'
    for agents_dir_str in os.environ.get('AGENT_PATH', str(AGENTS_DIR)).split(':'):
        agents_dir = Path(agents_dir_str)
        if not agents_dir.exists():
            continue
        
        print(f"  {agents_dir}:")
        components = list_components(agents_dir)
        
        if components['skills']:
            print(f"    skills: {', '.join(components['skills'])}")
        if components['commands']:
            print(f"    commands: {', '.join(components['commands'])}")
        
        if not components['skills'] and not components['commands']:
            print(f"    (no skills or commands)")
        
        print()

def list_enabled():
    print("Enabled components:")
    print()
    
    for comp_type, enabled_dir in sorted(ENABLED_DIRS.items()):
        if not enabled_dir.exists():
            continue
        
        links = list(enabled_dir.iterdir())
        if not links:
            continue
        
        print(f"  {comp_type}-enabled:")
        for link in sorted(links):
            print(f"    {link.name}")
        print()

def main():
    ensure_dirs()
    
    if len(sys.argv) < 2 or sys.argv[1] == '--help' or sys.argv[1] == '-h':
        print(__doc__)
        sys.exit(0)
    
    if sys.argv[1] == '--list':
        list_available()
        print()
        list_enabled()
        sys.exit(0)
    
    name = sys.argv[1]
    component_type, source_path = find_component(name)
    
    if not component_type:
        print(f"Error: '{name}' not found in any AGENT_PATH directory", file=sys.stderr)
        print(f"Run 'agent-list' to see available skills and commands", file=sys.stderr)
        sys.exit(1)
    
    enable_component(component_type, name, source_path)

if __name__ == '__main__':
    main()
