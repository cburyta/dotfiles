#!/bin/sh
#
# agent-hoist -- promote a skill/command from a tool directory
#                into a central agents/ directory, then sync everywhere
#
# Hoists into the first directory in AGENT_PATH by default,
# or a specific one with --dest.
#
# Usage:
#   agent-hoist                             # audit: list hoistable entities
#   agent-hoist skill   ~/.claude/skills/my-skill
#   agent-hoist command ~/.config/opencode/command/my-command.md
#   agent-hoist skill   ~/.claude/skills/my-skill --dest ~/Repos/work/agents

set -e

AGENT_PATH="${AGENT_PATH:-$HOME/.dotfiles/agents}"

usage() {
  echo "Usage: agent-hoist [<type> <source-path> [--dest <agents-dir>]]"
  echo ""
  echo "With no arguments: scan tool directories and list entities that can be hoisted."
  echo ""
  echo "With arguments: promote agent config from a tool-specific location into"
  echo "a central agents/ directory and re-sync to all tools."
  echo ""
  echo "Destination defaults to the first entry in AGENT_PATH."
  echo "Current AGENT_PATH: $AGENT_PATH"
  echo ""
  echo "Types:"
  echo "  skill     A skill directory containing SKILL.md"
  echo "  command   A command file (.md)"
  echo ""
  echo "Examples:"
  echo "  agent-hoist                                    # list what can be hoisted"
  echo "  agent-hoist skill   ~/.claude/skills/my-skill"
  echo "  agent-hoist command ~/.config/opencode/command/my-command.md"
  echo "  agent-hoist skill   ~/.claude/skills/my-skill --dest ~/Repos/work/agents"
  exit 1
}

# Returns 0 (true) if the given path is a symlink pointing into AGENT_PATH
is_managed() {
  local path="$1"
  [ -L "$path" ] || return 1
  local target
  target=$(readlink "$path")
  # Resolve relative symlink to absolute
  case "$target" in
    /*) ;;  # already absolute
    *)  target="$(cd "$(dirname "$path")" && cd "$target" 2>/dev/null && pwd || echo "$target")" ;;
  esac
  local dir
  IFS=':'
  for dir in $AGENT_PATH; do
    case "$target" in
      "$dir"*) unset IFS; return 0 ;;
    esac
  done
  unset IFS
  return 1
}

audit_hoistable() {
  SKILL_DIRS="$HOME/.claude/skills $HOME/.cursor/skills $HOME/.config/opencode/skills"
  COMMAND_DIRS="$HOME/.cursor/commands $HOME/.config/opencode/command $HOME/.claude/commands"

  found=0
  seen=""

  echo "Scanning for unmanaged entities..."
  echo ""

  for dir in $SKILL_DIRS; do
    [ -d "$dir" ] || continue
    for item in "$dir"/*/; do
      [ -d "$item" ] || continue
      item="${item%/}"  # strip trailing slash so readlink/-L work correctly
      is_managed "$item" && continue
      name=$(basename "$item")
      case " $seen " in
        *" skill:$name "*) continue ;;
      esac
      seen="$seen skill:$name"
      if [ ! -f "$item/SKILL.md" ]; then
        warn=" (no SKILL.md)"
      else
        warn=""
      fi
      printf "  skill    %-30s  %s%s\n" "$name" "$item" "$warn"
      printf "           agent-hoist skill %s\n" "$item"
      echo ""
      found=$((found + 1))
    done
  done

  for dir in $COMMAND_DIRS; do
    [ -d "$dir" ] || continue
    for item in "$dir"/*.md; do
      [ -f "$item" ] || continue
      is_managed "$item" && continue
      name=$(basename "$item")
      case " $seen " in
        *" command:$name "*) continue ;;
      esac
      seen="$seen command:$name"
      printf "  command  %-30s  %s\n" "$name" "$item"
      printf "           agent-hoist command %s\n" "$item"
      echo ""
      found=$((found + 1))
    done
  done

  if [ "$found" -eq 0 ]; then
    echo "Nothing to hoist — all entities in tool directories are already managed."
  else
    echo "$found entity(ies) can be hoisted."
    echo "Run the commands above, or pass a path directly: agent-hoist <type> <path>"
  fi
}

if [ $# -eq 0 ]; then
  audit_hoistable
  exit 0
fi

if [ $# -lt 2 ]; then
  usage
fi

TYPE="$1"
SOURCE="$2"
shift 2

DEST_ROOT=""
while [ $# -gt 0 ]; do
  case "$1" in
    --dest) DEST_ROOT="$2"; shift 2 ;;
    *)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
  esac
done

if [ -z "$DEST_ROOT" ]; then
  DEST_ROOT=$(echo "$AGENT_PATH" | cut -d: -f1)
fi

case "$TYPE" in
  skill)   DEST_DIR="$DEST_ROOT/skills" ;;
  command) DEST_DIR="$DEST_ROOT/commands" ;;
  *)
    echo "Error: unknown type '$TYPE'. Must be skill or command." >&2
    exit 1
    ;;
esac

if [ ! -e "$SOURCE" ]; then
  echo "Error: source path does not exist: $SOURCE" >&2
  exit 1
fi

NAME=$(basename "$SOURCE")
DEST="$DEST_DIR/$NAME"

if [ "$TYPE" = "skill" ]; then
  if [ ! -d "$SOURCE" ]; then
    echo "Error: skill source must be a directory: $SOURCE" >&2
    exit 1
  fi
  if [ ! -f "$SOURCE/SKILL.md" ]; then
    echo "Warning: no SKILL.md found in $SOURCE" >&2
  fi
fi

if [ -e "$DEST" ]; then
  echo "Error: $DEST already exists. Remove it first or pick a different name." >&2
  exit 1
fi

# If the source is already a symlink managed by agent-sync, nothing to do
if is_managed "$SOURCE"; then
  echo "$SOURCE is already managed by agent-sync. Nothing to hoist."
  exit 0
fi

echo "Hoisting $TYPE '$NAME' into $DEST_DIR/"

mkdir -p "$DEST_DIR"
cp -R "$SOURCE" "$DEST"
echo "  [copied] $SOURCE -> $DEST"

rm -rf "$SOURCE"
echo "  [removed] $SOURCE"

echo ""
echo "Running agent-sync to deploy everywhere..."
echo ""
agent-sync
