#!/usr/bin/env -S uv run --with claude-code-plugins-sdk --script
#
# agent-disable -- disable skills and commands
#
# Usage:
#   agent-disable <name>              # Disable skill or command by name
#   agent-disable --all                # Disable all enabled skills/commands
#   agent-disable --help              # Show help
#
# Examples:
#   agent-disable my-skill
#   agent-disable my-command
#   agent-disable --all

import os
import sys
from pathlib import Path

AGENTS_DIR = Path(os.environ.get('AGENTS_DIR', Path.home() / '.dotfiles' / 'agents'))
SKILLS_ENABLED = AGENTS_DIR / 'skills-enabled'
COMMANDS_ENABLED = AGENTS_DIR / 'commands-enabled'

ENABLED_DIRS = {
    'skills': SKILLS_ENABLED,
    'commands': COMMANDS_ENABLED,
}

def find_matching_links(name: str) -> list:
    matches = []
    
    for comp_type, enabled_dir in ENABLED_DIRS.items():
        if not enabled_dir.exists():
            continue
        
        for link in enabled_dir.iterdir():
            if name in link.name:
                matches.append((comp_type, link))
    
    return matches

def disable_component(name: str):
    matches = find_matching_links(name)
    
    if not matches:
        print(f"Error: No enabled component found matching '{name}'", file=sys.stderr)
        sys.exit(1)
    
    for comp_type, link in matches:
        try:
            link.unlink()
            print(f"  [disabled] {link.name} ({comp_type})")
        except OSError as e:
            print(f"  [error] Failed to remove {link.name}: {e}", file=sys.stderr)

def disable_all():
    disabled_count = 0
    
    for comp_type, enabled_dir in ENABLED_DIRS.items():
        if not enabled_dir.exists():
            continue
        
        for link in list(enabled_dir.iterdir()):
            try:
                link.unlink()
                print(f"  [disabled] {link.name} ({comp_type})")
                disabled_count += 1
            except OSError as e:
                print(f"  [error] Failed to remove {link.name}: {e}", file=sys.stderr)
    
    if disabled_count == 0:
        print("No components to disable")
    else:
        print(f"\nDisabled {disabled_count} component(s)")

def main():
    if len(sys.argv) < 2 or sys.argv[1] == '--help' or sys.argv[1] == '-h':
        print(__doc__)
        sys.exit(0)
    
    if sys.argv[1] == '--all':
        disable_all()
        sys.exit(0)
    
    name = sys.argv[1]
    disable_component(name)

if __name__ == '__main__':
    main()
